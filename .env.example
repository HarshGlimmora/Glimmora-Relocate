# Template for environment variables consumed by app/config.py.
#
# This file documents every env var the app reads. Copy to .env and fill in.
#
# APP_ENV=dev|staging|prod
# APP_LOG_LEVEL=INFO
# APP_HOST=0.0.0.0
# APP_PORT=8000
#
# POSTGRES_DSN=postgresql+asyncpg://user:pass@localhost:5432/relocate
# REDIS_URL=redis://localhost:6379/0
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_PROMPT_CACHE_ENABLED=true
#
# FX_PROVIDER_URL=  # optional; if empty, fallback to knowledge/data/fx_rates.json
# FX_REFRESH_TTL_SECONDS=3600
#
# FEATURE_LLM_INTENT_FALLBACK=true
# FEATURE_LLM_CULTURAL_ENRICH=true
# FEATURE_LLM_RECOMMENDATION_NARRATION=true
